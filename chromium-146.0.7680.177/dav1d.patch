From f8aef12d483e25db70ad499345130ae132aece8f Mon Sep 17 00:00:00 2001
From: Marcus Comstedt <marcus@mc.pp.se>
Date: Tue, 15 Jul 2025 12:55:13 +0200
Subject: [PATCH] Add ppc64 config

---
 third_party/dav1d/BUILD.gn                    | 28 ++++++
 third_party/dav1d/config/linux/ppc64/config.h | 99 +++++++++++++++++++
 third_party/dav1d/dav1d_generated.gni         |  1 +
 third_party/dav1d/generate_configs.py         |  1 +
 third_party/dav1d/generate_source.py          |  4 +
 third_party/dav1d/libdav1d/meson.build        |  2 +
 third_party/dav1d/libdav1d/src/cpu.h          |  2 +-
 .../dav1d/libdav1d/src/ppc/dav1d_types.h      | 15 +++
 8 files changed, 151 insertions(+), 1 deletion(-)
 create mode 100644 third_party/dav1d/config/linux/ppc64/config.h

diff --git a/third_party/dav1d/BUILD.gn b/third_party/dav1d/BUILD.gn
index c521fe2c68..49214f3acc 100644
--- a/third_party/dav1d/BUILD.gn
+++ b/third_party/dav1d/BUILD.gn
@@ -115,6 +115,10 @@ if (is_clang && (current_cpu == "arm" || current_cpu == "arm64" ||
   }
 }
 
+if (current_cpu == "ppc64") {
+  dav1d_copts += [ "-maltivec", "-mvsx" ]
+}
+
 if (enable_nasm) {
   nasm_assemble("dav1d_asm") {
     sources = x86_asm_sources
@@ -175,6 +179,8 @@ static_library("dav1d_8bit") {
     sources += arm_template_sources
   } else if (current_cpu == "arm64" || current_cpu == "arm64e") {
     sources += arm_template_sources
+  } else if (current_cpu == "ppc64") {
+    sources += ppc64_template_sources
   }
 
   cflags = dav1d_copts
@@ -205,6 +211,8 @@ static_library("dav1d_10bit") {
     sources += arm_template_sources
   } else if (current_cpu == "arm64" || current_cpu == "arm64e") {
     sources += arm_template_sources
+  } else if (current_cpu == "ppc64") {
+    sources += ppc64_template_sources
   }
 
   cflags = dav1d_copts
@@ -258,6 +266,24 @@ if (current_cpu == "x86" || current_cpu == "x64") {
 
     cflags = dav1d_copts
 
+    deps = [ ":dav1d_headers" ]
+    allow_circular_includes_from = [ ":dav1d_headers" ]
+  }
+} else if (current_cpu == "ppc64") {
+  static_library("dav1d_ppc") {
+    sources = [
+      "libdav1d/src/ppc/cpu.c",
+      "libdav1d/src/ppc/cpu.h",
+    ]
+
+    configs -= [ "//build/config/compiler:chromium_code" ]
+    configs += [
+      "//build/config/compiler:no_chromium_code",
+      ":dav1d_config",
+    ]
+
+    cflags = dav1d_copts
+
     deps = [ ":dav1d_headers" ]
     allow_circular_includes_from = [ ":dav1d_headers" ]
   }
@@ -312,5 +338,7 @@ static_library("dav1d") {
     deps += [ ":dav1d_arm" ]
   } else if (current_cpu == "riscv64") {
     deps += [ ":dav1d_riscv" ]
+  } else if (current_cpu == "ppc64") {
+    deps += [ ":dav1d_ppc" ]
   }
 }
diff --git a/third_party/dav1d/config/linux/ppc64/config.h b/third_party/dav1d/config/linux/ppc64/config.h
new file mode 100644
index 0000000000..1a5b748a6f
--- /dev/null
+++ b/third_party/dav1d/config/linux/ppc64/config.h
@@ -0,0 +1,99 @@
+/*
+ * Autogenerated by the Meson build system.
+ * Do not edit, your changes will be lost.
+ */
+
+#pragma once
+
+#define ARCH_AARCH64 0
+
+#define ARCH_ARM 0
+
+#define ARCH_LOONGARCH 0
+
+#define ARCH_LOONGARCH32 0
+
+#define ARCH_LOONGARCH64 0
+
+#define ARCH_PPC64 1
+
+#define ARCH_PPC64LE 0
+
+#define ARCH_RISCV 0
+
+#define ARCH_RV32 0
+
+#define ARCH_RV64 0
+
+#define ARCH_X86 0
+
+#define ARCH_X86_32 0
+
+#define ARCH_X86_64 0
+
+#define CONFIG_16BPC 1
+
+#define CONFIG_8BPC 1
+
+// #define CONFIG_LOG 1 -- Logging is controlled by Chromium
+
+#define CONFIG_MACOS_KPERF 0
+
+#define ENDIANNESS_BIG 1
+
+#define HAVE_ALIGNED_ALLOC 1
+
+#define HAVE_ASM 0
+
+#define HAVE_AS_ARCHEXT_DOTPROD_DIRECTIVE 0
+
+#define HAVE_AS_ARCHEXT_I8MM_DIRECTIVE 0
+
+#define HAVE_AS_ARCHEXT_SVE2_DIRECTIVE 0
+
+#define HAVE_AS_ARCHEXT_SVE_DIRECTIVE 0
+
+#define HAVE_AS_ARCH_DIRECTIVE 0
+
+#define HAVE_AS_FUNC 0
+
+#define HAVE_C11_GENERIC 1
+
+#define HAVE_CLOCK_GETTIME 1
+
+#define HAVE_DLSYM 1
+
+#define HAVE_DOTPROD 0
+
+#define HAVE_ELF_AUX_INFO 0
+
+#define HAVE_GETAUXVAL 1
+
+#define HAVE_I8MM 0
+
+#define HAVE_IO_H 0
+
+#define HAVE_MEMALIGN 1
+
+#define HAVE_POSIX_MEMALIGN 1
+
+// #define HAVE_PTHREAD_GETAFFINITY_NP 1 -- Controlled by Chomium
+
+#define HAVE_PTHREAD_NP_H 0
+
+// #define HAVE_PTHREAD_SETAFFINITY_NP 1 -- Controlled by Chomium
+
+#define HAVE_PTHREAD_SETNAME_NP 1
+
+#define HAVE_PTHREAD_SET_NAME_NP 0
+
+#define HAVE_SVE 0
+
+#define HAVE_SVE2 0
+
+#define HAVE_SYS_TYPES_H 1
+
+#define HAVE_UNISTD_H 1
+
+#define TRIM_DSP_FUNCTIONS 1
+
diff --git a/third_party/dav1d/dav1d_generated.gni b/third_party/dav1d/dav1d_generated.gni
index 3c5ad3a7e1..c40059c8d7 100644
--- a/third_party/dav1d/dav1d_generated.gni
+++ b/third_party/dav1d/dav1d_generated.gni
@@ -97,6 +97,7 @@ arm64_asm_sources = [
 ]
 
 arm_template_sources = []
+ppc64_template_sources = []
 riscv64_asm_sources = [
   "libdav1d/src/riscv/64/cdef.S",
   "libdav1d/src/riscv/64/cdef16.S",
diff --git a/third_party/dav1d/generate_configs.py b/third_party/dav1d/generate_configs.py
index aa1594d82b..1d41210f5c 100755
--- a/third_party/dav1d/generate_configs.py
+++ b/third_party/dav1d/generate_configs.py
@@ -216,6 +216,7 @@ def main():
     linux_env = os.environ
     linux_env['CC'] = 'clang'
 
+    GenerateConfig('config/linux/ppc64', linux_env)
     GenerateConfig('config/linux/x64', linux_env)
 
     noasm_dir = 'config/linux-noasm/x64'
diff --git a/third_party/dav1d/generate_source.py b/third_party/dav1d/generate_source.py
index d54c34f111..5fe62d4129 100755
--- a/third_party/dav1d/generate_source.py
+++ b/third_party/dav1d/generate_source.py
@@ -60,6 +60,10 @@ def _WriteGn(fd):
         fd, "riscv64_asm_sources",
         _Glob("libdav1d/src/riscv/64/*.S") + ["libdav1d/src/riscv/asm.S"])
 
+    _WriteArray(
+        fd, "ppc64_template_sources",
+        _Glob("libdav1d/src/ppc/*_tmpl.c"))
+
     template_sources = _Glob("libdav1d/src/*_tmpl.c")
     _WriteArray(fd, "template_sources", template_sources)
 
diff --git a/third_party/dav1d/libdav1d/meson.build b/third_party/dav1d/libdav1d/meson.build
index 2168b6ac21..c51f205dca 100644
--- a/third_party/dav1d/libdav1d/meson.build
+++ b/third_party/dav1d/libdav1d/meson.build
@@ -247,6 +247,7 @@ have_elf_aux_info = false
 if (host_machine.cpu_family() == 'aarch64' or
     host_machine.cpu_family().startswith('arm') or
     host_machine.cpu_family().startswith('loongarch') or
+    host_machine.cpu() == 'ppc64' or
     host_machine.cpu() == 'ppc64le' or
     host_machine.cpu_family().startswith('riscv'))
     have_getauxval = cc.has_function('getauxval', prefix : '#include <sys/auxv.h>', args : test_args)
@@ -508,6 +509,7 @@ if host_machine.cpu_family().startswith('x86')
     cdata_asm.set10('FORCE_VEX_ENCODING', cc.get_define('__AVX__').strip() != '')
 endif
 
+cdata.set10('ARCH_PPC64', host_machine.cpu() == 'ppc64')
 cdata.set10('ARCH_PPC64LE', host_machine.cpu() == 'ppc64le')
 
 cdata.set10('ARCH_RISCV', host_machine.cpu_family().startswith('riscv'))
diff --git a/third_party/dav1d/libdav1d/src/cpu.h b/third_party/dav1d/libdav1d/src/cpu.h
index 5d712bbbef..2e3d902b35 100644
--- a/third_party/dav1d/libdav1d/src/cpu.h
+++ b/third_party/dav1d/libdav1d/src/cpu.h
@@ -39,7 +39,7 @@
 #include "src/arm/cpu.h"
 #elif ARCH_LOONGARCH
 #include "src/loongarch/cpu.h"
-#elif ARCH_PPC64LE
+#elif ARCH_PPC64LE || ARCH_PPC64
 #include "src/ppc/cpu.h"
 #elif ARCH_RISCV
 #include "src/riscv/cpu.h"
diff --git a/third_party/dav1d/libdav1d/src/ppc/dav1d_types.h b/third_party/dav1d/libdav1d/src/ppc/dav1d_types.h
index 9a8bc7a732..7a6ca8d1bb 100644
--- a/third_party/dav1d/libdav1d/src/ppc/dav1d_types.h
+++ b/third_party/dav1d/libdav1d/src/ppc/dav1d_types.h
@@ -55,4 +55,19 @@
 #define u16l_to_i32(v) ((i32x4) vec_mergel((u16x8) v, vec_splat_u16(0)))
 #define i16l_to_i32(v) ((i32x4) vec_unpackl((i16x8)v))
 
+#if defined(__clang__)
+#undef vec_splats
+#define vec_splats(N)                     \
+    _Generic((N),                         \
+        unsigned char:      ((u8x16)(N)), \
+        signed char:        ((i8x16)(N)), \
+        unsigned short:     ((u16x8)(N)), \
+        signed short:       ((i16x8)(N)), \
+        unsigned int:       ((u32x4)(N)), \
+        signed int:         ((i32x4)(N)), \
+        unsigned long long: ((u64x2)(N)), \
+        signed long long:   ((i64x2)(N))  \
+    )
+#endif
+
 #endif /* DAV1D_SRC_PPC_TYPES_H */
-- 
2.53.0

