From 2592b8e2ead8ff959b1a67f6d52a586139351584 Mon Sep 17 00:00:00 2001
From: Marcus Comstedt <marcus@mc.pp.se>
Date: Sat, 6 Jun 2026 20:30:13 +0200
Subject: [PATCH 5/6] Disable pointer compression on ppc64

Pointer compression implies 31BIT_SMIS_ON_64BIT_ARCH, which tries
to use 32-bit accesses to access SMIs stored in 64-bit "registers"
on the stack.  Unfortunately, it uses the same base address for that
register when it does the 32-bit accesses as when it does 64-bit
accesses, which means it manipulates the upper 32 bits instead of the
lower 32 bits on big endian.

By disabling pointer compression, only 64 bit accesses are made to
these "registers", removing the problem.
---
 v8/gni/v8.gni | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/v8/gni/v8.gni b/v8/gni/v8.gni
index 78ae95633f..e29a7c5de3 100644
--- a/v8/gni/v8.gni
+++ b/v8/gni/v8.gni
@@ -316,7 +316,7 @@ assert(
 if (v8_enable_pointer_compression == "") {
   v8_enable_pointer_compression =
       v8_current_cpu == "arm64" || v8_current_cpu == "x64" ||
-      v8_current_cpu == "loong64" || v8_current_cpu == "ppc64"
+      v8_current_cpu == "loong64"
 }
 
 # The Wasm interpreter is currently supported only on arm64 and x64, on
-- 
2.53.0


