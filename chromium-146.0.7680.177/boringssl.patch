From f64597ca47ce340bbec17c3c94fffcb1b162c43b Mon Sep 17 00:00:00 2001
From: Marcus Comstedt <marcus@mc.pp.se>
Date: Tue, 4 Jul 2023 20:14:30 +0200
Subject: [PATCH 14/15] Fix Kyber on big endian

---
 .../src/crypto/fipsmodule/keccak/keccak.cc.inc | 18 ++++++++++++++++++
 1 file changed, 18 insertions(+)

diff --git a/third_party/boringssl/src/crypto/fipsmodule/keccak/keccak.cc.inc b/third_party/boringssl/src/crypto/fipsmodule/keccak/keccak.cc.inc
index 32be718568..3817b6a785 100644
--- a/third_party/boringssl/src/crypto/fipsmodule/keccak/keccak.cc.inc
+++ b/third_party/boringssl/src/crypto/fipsmodule/keccak/keccak.cc.inc
@@ -194,7 +194,11 @@ void bssl::BORINGSSL_keccak_absorb(struct BORINGSSL_keccak_st *ctx,
     assert(ctx->absorb_offset < ctx->rate_bytes);
     size_t first_block_len = ctx->rate_bytes - ctx->absorb_offset;
     for (size_t i = 0; i < first_block_len && i < in_len; i++) {
+#ifdef OPENSSL_BIGENDIAN
+      state_bytes[(ctx->absorb_offset + i) ^ 7] ^= in[i];
+#else
       state_bytes[ctx->absorb_offset + i] ^= in[i];
+#endif
     }
 
     // This input didn't fill the block.
@@ -221,7 +225,11 @@ void bssl::BORINGSSL_keccak_absorb(struct BORINGSSL_keccak_st *ctx,
   // Absorb partial block.
   assert(in_len < ctx->rate_bytes);
   for (size_t i = 0; i < in_len; i++) {
+#ifdef OPENSSL_BIGENDIAN
+    state_bytes[i ^ 7] ^= in[i];
+#else
     state_bytes[i] ^= in[i];
+#endif
   }
   ctx->absorb_offset = in_len;
 }
@@ -244,8 +252,13 @@ static void keccak_finalize(struct BORINGSSL_keccak_st *ctx) {
   // XOR the terminator. Accessing |ctx->state| as a |uint8_t*| is allowed by
   // strict aliasing because we require |uint8_t| to be a character type.
   uint8_t *state_bytes = (uint8_t *)ctx->state;
+#ifdef OPENSSL_BIGENDIAN
+  state_bytes[ctx->absorb_offset ^ 7] ^= terminator;
+  state_bytes[(ctx->rate_bytes - 1) ^ 7] ^= 0x80;
+#else
   state_bytes[ctx->absorb_offset] ^= terminator;
   state_bytes[ctx->rate_bytes - 1] ^= 0x80;
+#endif
   keccak_f(ctx->state);
 }
 
@@ -278,7 +291,12 @@ void bssl::BORINGSSL_keccak_squeeze(struct BORINGSSL_keccak_st *ctx,
     if (todo > remaining) {
       todo = remaining;
     }
+#ifdef OPENSSL_BIGENDIAN
+    for (size_t i = 0; i < todo; i++)
+      out[i] = state_bytes[(ctx->squeeze_offset + i)^7];
+#else
     OPENSSL_memcpy(out, &state_bytes[ctx->squeeze_offset], todo);
+#endif
     out += todo;
     out_len -= todo;
     ctx->squeeze_offset += todo;
